:root {
  --theme-1: #0b4f9c;
  --theme-2: #2b78cc;
  --theme-3: #4ea2ff;
  --list-bg: rgba(18, 24, 31, 0.72);
  --row-bg: rgba(34, 41, 50, 0.72);
  --text: #f4f4f4;
  --active-bg: rgba(236, 236, 236, 0.98);
  --active-text: #111;
  --title: #ffffff;
  --count: #ffffff;
  --shadow: none;
}

* {
  box-sizing: border-box;
  user-select: none;
}

html, body {
  margin: 0;
  width: 100%;
  height: 100%;
  background: transparent;
  overflow: hidden;
  font-family: Tahoma, Verdana, Arial, sans-serif;
}

body {
  pointer-events: none;
}

.shell {
  position: absolute;
  top: 18px;
  left: 18px;
  width: 431px;
  display: none;
  pointer-events: auto;
  transform-origin: top left;
}

.shell.right {
  left: auto;
  right: 18px;
  transform-origin: top right;
}

.shell.open {
  display: block;
}

.menu-panel {
  width: 100%;
  box-shadow: none;
}

.menu-header {
  position: relative;
  height: 90px;
  background: linear-gradient(180deg, var(--theme-1), var(--theme-2));
  background-size: cover;
  background-position: center;
  overflow: hidden;
}

.header-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0));
}

.header-top {
  position: relative;
  z-index: 1;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 18px;
}

.brand-stack {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  min-width: 0;
  width: 100%;
}

.banner-logo {
  width: 38px;
  height: 38px;
  object-fit: contain;
  background: transparent;
}

.brand-script {
  color: #fff;
  font-size: 38px;
  line-height: 1;
  font-style: italic;
  letter-spacing: 0.3px;
  font-family: "Segoe Script", "Lucida Handwriting", cursive;
  text-shadow: 0 1px 2px rgba(0,0,0,0.16);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.header-side,
.icon-btn,
.mini-badge {
  display: none !important;
}

.menu-title-row {
  height: 34px;
  background: rgba(0,0,0,0.96);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 10px 0 12px;
}

.menu-title {
  color: var(--title);
  font-weight: 400;
  font-size: 16px;
  text-transform: none;
}

.menu-count {
  color: var(--count);
  font-weight: 400;
  font-size: 16px;
}

.menu-list-wrap {
  background: var(--list-bg);
}

.menu-list {
  max-height: 402px;
  overflow-y: auto;
  overflow-x: hidden;
  scrollbar-width: thin;
  padding-right: 0;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 38px;
  min-width: 0;
  padding: 7px 10px 7px 12px;
  color: var(--text);
  font-size: 15px;
  background: var(--row-bg);
  border-bottom: 1px solid rgba(255,255,255,0.04);
  gap: 10px;
}

.menu-item .label {
  flex: 1 1 auto;
  min-width: 0;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-item.active {
  background: var(--active-bg);
  color: var(--active-text);
}

.menu-item .value,
.menu-item .check,
.menu-item .arrow {
  flex: 0 0 auto;
  color: inherit;
  font-weight: 700;
  white-space: nowrap;
  min-width: 28px;
  text-align: right;
}

.menu-item.disabled {
  opacity: 0.5;
}

.scroll-indicator {
  text-align: center;
  font-size: 18px;
  color: rgba(255,255,255,0.95);
  background: rgba(0,0,0,0.88);
  height: 22px;
  line-height: 20px;
  letter-spacing: 4px;
}

.description-box {
  min-height: 78px;
  padding: 10px 12px;
  background: rgba(0,0,0,0.86);
  color: white;
  font-size: 14px;
  line-height: 1.24;
}

.toast {
  margin-top: 8px;
  padding: 8px 10px;
  background: rgba(0,0,0,0.9);
  color: white;
  font-size: 13px;
  white-space: pre-wrap;
}

.hidden {
  display: none !important;
}

.modal {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.45);
}

.modal-card {
  width: 470px;
  max-width: calc(100vw - 80px);
  background: rgba(0,0,0,0.94);
  border: 1px solid rgba(255,255,255,0.12);
  color: white;
  padding: 14px;
}

.modal-title {
  font-size: 17px;
  color: white;
  font-weight: 700;
  margin-bottom: 10px;
}

.modal-fields {
  display: grid;
  gap: 10px;
}

.modal-fields label {
  display: grid;
  gap: 6px;
  font-size: 14px;
  color: #e8edf5;
}

.modal-fields input,
.modal-display {
  width: 100%;
  padding: 10px 11px;
  background: rgba(255,255,255,0.06);
  color: white;
  border: 1px solid rgba(255,255,255,0.08);
  outline: none;
  font: inherit;
}

.modal-display-wrap {
  margin-top: 6px;
}

.modal-display {
  min-height: 165px;
  resize: none;
  line-height: 1.3;
}

.modal-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  margin-top: 14px;
}

.modal-btn {
  min-width: 96px;
  height: 36px;
  border: 0;
  cursor: pointer;
  background: linear-gradient(180deg, var(--theme-2), var(--theme-1));
  color: white;
  font-weight: 700;
}

.modal-btn.secondary {
  background: rgba(255,255,255,0.12);
}
